{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LoadingIndicatorProps",
  "type": "object",
  "properties": {
    "className": {
      "type": "string"
    },
    "size": {
      "type": "string",
      "enum": ["small", "medium", "large"]
    },
    "color": {
      "type": "string"
    },
    "dotCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 6
    },
    "label": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
